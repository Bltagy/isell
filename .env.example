# ═══════════════════════════════════════════════════════════════════════════════
# SaaS Food Ordering System — Environment Variables
# Copy this file to .env and fill in your values before running docker compose
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App Settings ───────────────────────────────────────────────────────────────
APP_NAME="Food App"                  # Display name of the application
APP_ENV=local                        # Environment: local | staging | production
APP_KEY=                             # Laravel encryption key — run: php artisan key:generate
APP_DEBUG=true                       # Show detailed errors (set false in production)
APP_URL=http://localhost             # Full base URL of the application
APP_DOMAIN=localhost                 # Root domain used for subdomain-based tenant routing

APP_TIMEZONE=Africa/Cairo
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# ─── Database ───────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql                  # Database driver (mysql)
DB_HOST=mysql8                       # Database host (Docker service name)
DB_PORT=3350                         # Database port (host-side mapping)
DB_DATABASE=foodapp_central          # Central database name (stores tenants, plans, subscriptions)
DB_USERNAME=foodapp                  # Database user
DB_PASSWORD=secret                   # Database user password
DB_ROOT_PASSWORD=rootpassword        # MySQL root password (used by Docker to initialise the server)

TENANCY_CENTRAL_DOMAINS=localhost    # Comma-separated list of central (non-tenant) domains

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis                # PHP Redis client: phpredis | predis
REDIS_HOST=redis                     # Redis host (Docker service name)
REDIS_PORT=6379                      # Redis port
REDIS_PASSWORD=redispassword         # Redis authentication password (leave null to disable auth)

# ─── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp                     # Mail driver: smtp | sendmail | mailgun | ses | log
MAIL_HOST=mailpit                    # SMTP host (Mailpit for local dev, real SMTP for production)
MAIL_PORT=1025                       # SMTP port (1025 for Mailpit, 587 for TLS, 465 for SSL)
MAIL_USERNAME=null                   # SMTP username (null for Mailpit)
MAIL_PASSWORD=null                   # SMTP password (null for Mailpit)
MAIL_FROM_ADDRESS="noreply@foodapp.com"  # Default sender address
MAIL_FROM_NAME="${APP_NAME}"         # Default sender name

# ─── Meilisearch ────────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700  # Meilisearch server URL
MEILISEARCH_KEY=masterkey                 # Meilisearch master API key
SCOUT_DRIVER=meilisearch                  # Laravel Scout driver for full-text product search

# ─── MinIO / S3 Storage ─────────────────────────────────────────────────────────
FILESYSTEM_DISK=s3                   # Default filesystem disk (s3 = MinIO in dev)
AWS_ACCESS_KEY_ID=minioadmin         # S3 / MinIO access key ID
AWS_SECRET_ACCESS_KEY=minioadmin123  # S3 / MinIO secret access key
AWS_DEFAULT_REGION=us-east-1         # S3 region (any value works for MinIO)
AWS_BUCKET=foodapp                   # S3 bucket name for storing media files
AWS_ENDPOINT=http://minio:9000       # MinIO API endpoint (override for non-AWS S3)
AWS_USE_PATH_STYLE_ENDPOINT=true     # Use path-style URLs required by MinIO (true | false)
MINIO_ROOT_USER=minioadmin           # MinIO root username (used by the MinIO Docker container)
MINIO_ROOT_PASSWORD=minioadmin123    # MinIO root password (used by the MinIO Docker container)

# ─── Laravel Reverb (WebSockets) ────────────────────────────────────────────────
REVERB_APP_ID=foodapp                # Reverb application ID (unique identifier for this app)
REVERB_APP_KEY=foodapp-key           # Reverb application key (used by clients to connect)
REVERB_APP_SECRET=foodapp-secret     # Reverb application secret (used to sign messages)
REVERB_HOST=laravel-reverb           # Reverb server host (Docker service name)
REVERB_PORT=8060                     # Reverb server port
REVERB_SCHEME=http                   # Connection scheme: http | https

# ─── Queue ──────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis               # Queue driver: sync | redis | database | sqs
HORIZON_PREFIX=foodapp_horizon:      # Redis key prefix for Laravel Horizon queue metrics

# ─── Broadcasting ───────────────────────────────────────────────────────────────
BROADCAST_DRIVER=reverb              # Broadcasting driver: reverb | pusher | log | null

# ─── Cache & Session ────────────────────────────────────────────────────────────
CACHE_DRIVER=redis                   # Cache driver: redis | memcached | file | array
SESSION_DRIVER=redis                 # Session storage driver: redis | file | cookie | database
SESSION_LIFETIME=120                 # Session lifetime in minutes

# ─── Next.js Dashboard ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api/v1          # Laravel API base URL consumed by the dashboard
NEXT_PUBLIC_REVERB_APP_KEY=foodapp-key               # Reverb app key for the dashboard WebSocket client
NEXT_PUBLIC_REVERB_HOST=localhost                    # Reverb host reachable from the browser
NEXT_PUBLIC_REVERB_PORT=8060                         # Reverb port reachable from the browser

# ─── Kashier Payment Gateway ────────────────────────────────────────────────────
KASHIER_MERCHANT_ID=                 # Kashier merchant ID (obtain from Kashier dashboard)
KASHIER_API_KEY=                     # Kashier API key for HMAC signature generation
KASHIER_MODE=test                    # Gateway mode: test | live
KASHIER_BASE_URL=https://checkout.kashier.io  # Kashier checkout base URL
KASHIER_WEBHOOK_SECRET=              # Secret used to verify incoming Kashier webhook signatures

# ─── Firebase (FCM Push Notifications) ──────────────────────────────────────────
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json  # Path to Firebase service account JSON
FCM_SERVER_KEY=                      # Firebase Cloud Messaging server key for push notifications

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack                    # Log channel: stack | single | daily | stderr
LOG_LEVEL=debug                      # Minimum log level: debug | info | warning | error

# ─── Docker ─────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=foodapp         # Docker Compose project name (prefixes container and network names)

# ─── Host IP ────────────────────────────────────────────────────────────────────
# LAN IP of the machine running Docker.
# Used by: nginx server_name, Next.js NEXT_PUBLIC_API_URL, NEXT_PUBLIC_REVERB_HOST
# Find it with: ip route get 1 | awk '{print $7}' (Linux) or ipconfig (Windows)
HOST_IP=isell.dev-ark.com
