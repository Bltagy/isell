{
  "info": {
    "name": "Food App API",
    "description": "Multi-tenant SaaS Food Ordering System — Phase 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://demo.localhost/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Test User\",\"email\":\"test@example.com\",\"phone\":\"+201000000099\",\"password\":\"password\",\"password_confirmation\":\"password\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@foodapp.com\",\"password\":\"password\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/send-otp",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\":\"+201000000099\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/verify-otp",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\":\"+201000000099\",\"otp\":\"123456\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Settings",
      "item": [
        {
          "name": "App Config",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/settings/app-config",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Home",
      "item": [
        {
          "name": "Home Feed",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/home",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Category Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/1/products",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products?page=1&per_page=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "category_id", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "is_featured", "value": "true", "disabled": true },
                { "key": "sort_by", "value": "price_asc", "disabled": true }
              ]
            },
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/1",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Product Reviews",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/1/reviews",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"items\":[{\"product_id\":1,\"quantity\":2}],\"address_id\":1,\"payment_method\":\"cash\",\"notes\":\"Extra spicy please\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/1",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders/1/cancel",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Track Order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/1/track",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Offers",
      "item": [
        {
          "name": "Validate Offer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/offers/validate",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"code\":\"WELCOME20\",\"subtotal_piastres\":10000}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/profile",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/profile",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Updated Name\",\"preferred_language\":\"ar\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update FCM Token",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/profile/update-fcm-token",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"fcm_token\":\"your-fcm-token-here\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Addresses",
      "item": [
        {
          "name": "List Addresses",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/addresses",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/addresses",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"label\":\"home\",\"address_line1\":\"123 Tahrir Square\",\"city\":\"Cairo\",\"district\":\"Downtown\",\"latitude\":30.0444,\"longitude\":31.2357,\"is_default\":true}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Unread Count",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications/unread-count",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/notifications/read-all",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Favorites",
      "item": [
        {
          "name": "My Favorites",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/favorites",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Toggle Favorite",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/favorites/1/toggle",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/reviews",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"order_id\":1,\"product_id\":1,\"rating\":5,\"comment\":\"Excellent food!\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/dashboard/stats",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/orders",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/orders/1/status",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"confirmed\",\"note\":\"Order confirmed by admin\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/settings",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/settings",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"settings\":{\"app_name_en\":\"My Restaurant\",\"primary_color\":\"#FF0000\"}}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Broadcast Notification",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/notifications/broadcast",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"target\":\"all\",\"title_en\":\"Special Offer!\",\"title_ar\":\"عرض خاص!\",\"body_en\":\"Get 20% off today only.\",\"body_ar\":\"احصل على خصم 20% اليوم فقط.\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
